# API Keys for Memory Agent
# Copy this file to .env and fill in your API keys

# Mem0 (REQUIRED - FREE, no credit card required)
# Provides cloud memory storage for your agent
# Sign up and get your FREE key at: https://app.mem0.ai/dashboard
MEM0_API_KEY=your-mem0-api-key-here

# LLM Provider (Choose ONE - the agent uses LiteLLM, so you can use ANY provider)
# Anthropic (Used by default in this lab - students can replace with any provider)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alternative LLM providers (uncomment and use any one):
# Groq (FREE, no credit card required)
# Get your key at: https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key-here

# OpenAI (Paid)
# Get your key at: https://platform.openai.com/
# OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (Free tier available)
# Get your key at: https://aistudio.google.com/
# GEMINI_API_KEY=your-gemini-api-key-here
